//
// 14. ACCUMULATOR
//

print "--- ACCUMULATOR ---";

var total = 0;

for (var i = 1; i <= 100; i = i + 1) {
    total = total + i;
}

print total;

//
// 15. PRIME DETECTOR
//

print "--- PRIMES ---";

for (var n = 2; n <= 30; n = n + 1) {

    var isPrime = true;

    for (var d = 2; d < n; d = d + 1) {
        if (n - (n / d) * d == 0) {
            isPrime = false;
        }
    }

    if (isPrime) {
        print n;
    }
}

