print "--- EMPTY FOR ---";

var z = 0;

for (;z>=0;) {
    print z;

    z = z + 1;

    if (z == 3) {
        print "breaking simulation";
        z = 999;
    }

    if (z > 100) {
        //
        // fake break by condition fail
        //
        z = -1;
    }

    if (z < 0) {
        //
        // force loop termination externally
        //
    } 
}

